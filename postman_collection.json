{
  "info": {
    "name": "OTUS Social Network",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Сергей\",\n  \"second_name\": \"Иванов\",\n  \"birthdate\": \"1990-01-15\",\n  \"biography\": \"Программирование, музыка\",\n  \"city\": \"Москва\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/user/register",
          "host": ["{{base_url}}"],
          "path": ["user", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.user_id) {",
              "    pm.collectionVariables.set('user_id', jsonData.user_id);",
              "}",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has user_id', function () {",
              "    pm.expect(jsonData).to.have.property('user_id');",
              "    pm.expect(jsonData.user_id).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{user_id}}\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set('token', jsonData.token);",
              "}",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has token', function () {",
              "    pm.expect(jsonData).to.have.property('token');",
              "    pm.expect(jsonData.token).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Get User",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/user/get/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["user", "get", "{{user_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has all fields', function () {",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('first_name');",
              "    pm.expect(jsonData).to.have.property('second_name');",
              "    pm.expect(jsonData).to.have.property('birthdate');",
              "    pm.expect(jsonData).to.have.property('biography');",
              "    pm.expect(jsonData).to.have.property('city');",
              "});",
              "",
              "pm.test('Fields have correct values', function () {",
              "    pm.expect(jsonData.first_name).to.eql('Сергей');",
              "    pm.expect(jsonData.second_name).to.eql('Иванов');",
              "    pm.expect(jsonData.birthdate).to.eql('1990-01-15');",
              "    pm.expect(jsonData.biography).to.eql('Программирование, музыка');",
              "    pm.expect(jsonData.city).to.eql('Москва');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Login - Wrong Password (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{user_id}}\",\n  \"password\": \"wrong_password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Get User - Not Found (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/user/get/00000000-0000-0000-0000-000000000000",
          "host": ["{{base_url}}"],
          "path": ["user", "get", "00000000-0000-0000-0000-000000000000"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Get User - Invalid ID (400)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/user/get/not-a-uuid",
          "host": ["{{base_url}}"],
          "path": ["user", "get", "not-a-uuid"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
